# ── 双模型策略 ──
# Workhorse: deepseek-chat    (主力: 角色/场景/剧本生成 — 128K 上下文 + Context Caching)
# Reasoner:  deepseek-reasoner (大脑: R1 深度推理校验 — CoT 思维链质检)
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
LLM_REASONER_MODEL=deepseek-reasoner

# ── 超参 ──
LLM_WORKHORSE_TEMPERATURE=0.7
LLM_REASONER_TEMPERATURE=0.0

# ── HITL ──
HITL_CONFIDENCE_THRESHOLD=0.7
MAX_RETRIES=3

# ── 存储 ──
DATABASE_PATH=data/state.db
DATA_DIR=data
